# 실데이터 소스 (필수) — 카카오 로컬 API REST 키
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_REST_KEY=

# (선택) 노포 정확 판별 — 행정안전부 지방행정 인허가데이터 authKey
# 발급: https://www.localdata.go.kr → 개발지원 → API신청 (일반음식점 07_24_04_P)
# 있으면 인허가일자(개업일)로 정확한 노포 연차를 판정합니다.
LOCALDATA_KEY=

# (선택) 서버 포트
